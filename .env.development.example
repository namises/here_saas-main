# Development Environment Variables

# Server Configuration
NODE_ENV=development
PORT=3000

# Database
MONGO_URI=mongodb://localhost:27017/here_dev

# JWT Authentication
JWT_SECRET=dev_secret_key_change_in_production

# Client Configuration
CLIENT_URI=http://localhost:5173
VITE_API_BASE_URL=http://localhost:3000/api

# Firebase Configuration (Development Project)
type=service_account
project_id=your-dev-firebase-project-id
private_key_id=your_dev_private_key_id
private_key=-----BEGIN PRIVATE KEY-----\nYour_Dev_Private_Key_Here\n-----END PRIVATE KEY-----
client_email=firebase-adminsdk-xxxxxx@your-dev-firebase-project-id.iam.gserviceaccount.com
client_id=your_dev_client_id
auth_uri=https://accounts.google.com/o/oauth2/auth
token_uri=https://oauth2.googleapis.com/token
auth_provider_x509_cert_url=https://www.googleapis.com/oauth2/v1/certs
client_x509_cert_url=https://www.googleapis.com/robot/v1/metadata/x509/firebase-adminsdk-xxxxxx%40your-dev-firebase-project-id.iam.gserviceaccount.com
universe_domain=googleapis.com

# Cloudinary Configuration (Development Account)
CLOUDINARY_CLOUD_NAME=your_dev_cloud_name
CLOUDINARY_API_KEY=your_dev_api_key
CLOUDINARY_API_SECRET=your_dev_api_secret

# Email Configuration (Brevo/Sendinblue - Development)
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=your_dev_brevo_email
BREVO_SMTP_PASS=your_dev_brevo_password
